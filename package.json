{
  "name": "content_management_platform",
  "version": "1.0.0",
  "description": "Lightweight app to manage content in github pages",
  "main": "app.js",
  "bin": {
    "cms": "./bin/cms.js"
  },
  "scripts": {
    "start": "cross-env NODE_ENV=production node app.js",
    "dev:server": "cross-env NODE_ENV=development nodemon app.js",
    "dev:client": "vite",
    "build": "vite build",
    "dev": "concurrently \"npm:dev:server\" \"npm:dev:client\"",
    "electron:dev": "concurrently --kill-others \"npm:dev:server\" \"npm:dev:client\" \"wait-on http://127.0.0.1:3000 http://127.0.0.1:5173 && cross-env NODE_ENV=development electron electron/main.js\"",
    "electron:build": "vite build && electron-builder --config electron-builder.yml",
    "electron:rebuild": "electron-rebuild -f -w better-sqlite3"
  },
  "keywords": [],
  "author": "Tech Tana",
  "license": "MIT",
  "packageManager": "pnpm@10.15.1",
  "dependencies": {
    "@octokit/rest": "^22.0.1",
    "better-sqlite3": "^12.9.0",
    "dotenv": "^17.2.2",
    "express": "^5.1.0",
    "express-rate-limit": "^8.4.1",
    "express-validator": "^7.3.2",
    "gray-matter": "^4.0.3",
    "js-yaml": "^4.1.1",
    "luxon": "^3.7.2",
    "morgan": "^1.10.1",
    "open": "^11.0.0",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "react-router-dom": "^7.14.2",
    "uuid": "^14.0.0"
  },
  "devDependencies": {
    "@electron/rebuild": "^3.7.2",
    "@vitejs/plugin-react": "^6.0.1",
    "concurrently": "^9.2.1",
    "cross-env": "^10.0.0",
    "electron": "^36.9.5",
    "electron-builder": "^26.8.1",
    "nodemon": "^3.1.10",
    "vite": "^8.0.10",
    "wait-on": "^8.0.5"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "better-sqlite3",
      "electron",
      "electron-winstaller"
    ]
  }
}
